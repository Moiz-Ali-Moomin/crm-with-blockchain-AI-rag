# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Multi-Provider AI CRM Backend
#
# Copy this file to .env and fill in your real values.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=production
PORT=3001

APP_URL=https://your-domain.com
API_URL=https://your-domain.com/api/v1
CORS_ORIGINS=https://your-domain.com

NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ─────────────────────────────────────────
# Database (Postgres)
# Generate password: openssl rand -base64 32
# ─────────────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=crm_db
DATABASE_URL=postgresql://crm_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/crm_db?schema=public

# ─────────────────────────────────────────
# Redis
# Generate password: openssl rand -base64 32
# ─────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_STRONG_PASSWORD@redis:6379

# ─────────────────────────────────────────
# MongoDB
# Generate password: openssl rand -base64 32
# ─────────────────────────────────────────
MONGO_USER=crm_mongo
MONGO_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MONGO_URI=mongodb://crm_mongo:REPLACE_WITH_STRONG_PASSWORD@mongodb:27017/crm_logs?authSource=admin

# ─────────────────────────────────────────
# Authentication
# Generate: openssl rand -base64 64
# ─────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_SECURE_JWT_SECRET_40_PLUS_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_SECURE_JWT_REFRESH_SECRET_40_PLUS_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# Email
# ─────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@your-domain.com
SENDGRID_FROM_NAME=CRM Platform

# ─────────────────────────────────────────
# Twilio
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_FREE=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_PLUS=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_ULTIMATE=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# PayPal
# ─────────────────────────────────────────
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_PLAN_STARTER=P-xxxxxxxxxxxxxxxx
PAYPAL_PLAN_PRO=P-xxxxxxxxxxxxxxxx
PAYPAL_PLAN_PRO_PLUS=P-xxxxxxxxxxxxxxxx
PAYPAL_PLAN_ULTIMATE=P-xxxxxxxxxxxxxxxx
PAYPAL_PLAN_ENTERPRISE=P-xxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# AI — Core Feature Flag
# Set to true to enable all AI features
# ─────────────────────────────────────────
ENABLE_AI=true

# ─────────────────────────────────────────
# AI — LLM Providers
#
# Primary:  anthropic | openai
# Fallback: openai | anthropic | none
#
# The factory tries the primary on every request.
# If the primary fails, the fallback is used automatically.
# ─────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_FALLBACK=openai

# Required when LLM_PROVIDER=anthropic or LLM_FALLBACK=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Required when LLM_PROVIDER=openai or LLM_FALLBACK=openai
OPENAI_API_KEY=sk-your-openai-key-here

# Optional LLM tuning (safe to leave commented out — defaults apply)
# LLM_MODEL=claude-3-5-sonnet-20241022    # override Anthropic model
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.2

# ─────────────────────────────────────────
# AI — Embedding Providers
#
# Primary:  ollama | openai
# Fallback: openai | none
#
# Ollama runs locally — zero cost, no API key needed.
# Requires: ollama serve && ollama pull nomic-embed-text
# ─────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_FALLBACK=openai

# Ollama local server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Ollama embedding model (default: nomic-embed-text)
OLLAMA_MODEL=nomic-embed-text

# ─────────────────────────────────────────
# Blockchain
# Leave blank to disable (app degrades gracefully)
# ─────────────────────────────────────────
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDR=

# ─────────────────────────────────────────
# Observability
# ─────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ALERTMANAGER_SMTP_USER=your-email@gmail.com
ALERTMANAGER_SMTP_PASSWORD=your-gmail-app-password
ALERTMANAGER_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────
# Backups
# ─────────────────────────────────────────
BACKUP_KEEP_DAYS=7
